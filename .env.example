# Copy this file to .env and fill in values
# Ollama runs locally — no API key needed!
OLLAMA_HOST=http://localhost:11434

# Which models to benchmark (must be pulled via: ollama pull <name>)
MODELS=llama3,mistral,phi3:mini

# How many times to run each prompt per model (more = more reliable averages)
RUNS_PER_PROMPT=1
